# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# openrouter/free auto-selects a free model that supports tool calling.
# Fallback is also a free (":free" suffix) model - no paid/cost models are used.
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Random secret used to sign the Flask session cookie. Generate your own with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-a-random-64-char-hex-string

DATABASE_URL=sqlite:///restaurant.db
FLASK_DEBUG=1
